# ── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_AI_API_KEY=AIza-your-key-here
GROQ_API_KEY=gsk_your-key-here
MISTRAL_API_KEY=your-mistral-key
OPENROUTER_API_KEY=sk-or-your-key-here

# ── App ────────────────────────────────────────────────────
APP_NAME=AI Automation Toolkit
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://ait_user:ait_pass@localhost:5432/ait_db
REDIS_URL=redis://localhost:6379/0

# ── Storage ────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-automation-files

# ── Integrations ───────────────────────────────────────────
GITHUB_TOKEN=ghp_your-token-here
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret
DISCORD_BOT_TOKEN=your-discord-token
TELEGRAM_BOT_TOKEN=your-telegram-token
NOTION_API_KEY=secret_your-notion-key

# ── Google ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Automation Toolkit
